---
// KINETIC PRINT LAB — HOME MANIFEST
// src/pages/index.astro
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KINETIC PRINT LAB</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />

  <style>
    /* ── RESET & BASE ─────────────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --ink-black:    #0a0a0a;
      --paper:        #f0ece3;
      --fluro-pink:   #ff3c96;
      --toxic-green:  #b8ff00;
      --border:       6px solid var(--ink-black);
      --border-thin:  3px solid var(--ink-black);
      --font-display: 'Bebas Neue', sans-serif;
      --font-mono:    'JetBrains Mono', monospace;
    }

    html {
      background: var(--ink-black);
      color: var(--paper);
      font-family: var(--font-mono);
      font-size: 16px;
      line-height: 1.5;
    }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      border: var(--border);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    /* ── UTILITY ──────────────────────────────────────────── */
    .label {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.5;
    }

    /* ── NAV ──────────────────────────────────────────────── */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 1.5rem;
      border-bottom: var(--border);
    }

    .nav-wordmark {
      font-family: var(--font-display);
      font-size: 1.4rem;
      letter-spacing: 0.05em;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0.7;
      transition: opacity 0.15s;
    }

    .nav-links a:hover {
      opacity: 1;
    }

    /* ── HERO ─────────────────────────────────────────────── */
    .hero {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 3rem 1.5rem 0;
      border-bottom: var(--border);
      overflow: hidden;
    }

    .hero-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .hero-headline-wrap {
      flex: 1;
    }

    .hero-eyebrow {
      display: block;
      margin-bottom: 0.75rem;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(5rem, 14vw, 14rem);
      line-height: 0.92;
      letter-spacing: -0.01em;
      text-transform: uppercase;
    }

    .hero-headline span {
      display: block;
    }

    /* Staggered stamp-in animation */
    .stamp-line {
      opacity: 0;
      transform: translateY(12px);
      animation: stamp-in 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .stamp-line:nth-child(1) { animation-delay: 0.05s; }
    .stamp-line:nth-child(2) { animation-delay: 0.18s; }
    .stamp-line:nth-child(3) { animation-delay: 0.31s; }

    @keyframes stamp-in {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .stamp-line {
        opacity: 1;
        transform: none;
        animation: none;
      }
    }

    /* ── TELEMETRY BOX ────────────────────────────────────── */
    .telemetry {
      flex-shrink: 0;
      border: var(--border);
      padding: 1.25rem 1.5rem;
      min-width: 280px;
      max-width: 320px;
    }

    .telemetry-header {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: var(--border-thin);
      opacity: 0.5;
    }

    .telemetry-row {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      font-size: 0.7rem;
      margin-bottom: 0.5rem;
      line-height: 1.4;
    }

    .telemetry-key {
      opacity: 0.5;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .telemetry-val {
      text-align: right;
      font-weight: 700;
    }

    .telemetry-val.active {
      color: var(--toxic-green);
    }

    .status-dot {
      display: inline-block;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--toxic-green);
      margin-right: 0.4em;
      animation: pulse-dot 1.8s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    @media (prefers-reduced-motion: reduce) {
      .status-dot { animation: none; }
    }

    /* ── MANIFESTO BAND ───────────────────────────────────── */
    .manifesto {
      border-top: var(--border);
      padding: 2.5rem 1.5rem;
      background: var(--paper);
      color: var(--ink-black);
    }

    .manifesto-text {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 3.5vw, 3rem);
      line-height: 1.1;
      letter-spacing: 0.02em;
      max-width: 70ch;
    }

    /* ── CTA ──────────────────────────────────────────────── */
    .cta-section {
      border-top: var(--border);
    }

    .cta-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 2rem 1.5rem;
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 6vw, 5.5rem);
      letter-spacing: 0.04em;
      background: var(--ink-black);
      color: var(--paper);
      transition: background 0.15s, color 0.15s;
      gap: 1rem;
    }

    .cta-link:hover {
      background: var(--fluro-pink);
      color: var(--ink-black);
    }

    .cta-link:hover .cta-arrow {
      transform: translateX(6px);
    }

    .cta-arrow {
      display: inline-block;
      transition: transform 0.15s;
      flex-shrink: 0;
    }

    /* ── FOOTER ───────────────────────────────────────────── */
    footer {
      border-top: var(--border);
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-copy {
      font-size: 0.65rem;
      opacity: 0.4;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .footer-drums {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .drum {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: 2px solid currentColor;
    }

    .drum--pink  { background: var(--fluro-pink);  border-color: var(--fluro-pink); }
    .drum--green { background: var(--toxic-green); border-color: var(--toxic-green); }
    .drum--black { background: var(--paper);        border-color: var(--paper); }

    /* ── MOBILE ───────────────────────────────────────────── */
    @media (max-width: 768px) {
      :root {
        --border: 3px solid var(--ink-black);
      }

      body {
        border-width: 3px;
      }

      .hero-top {
        flex-direction: column;
      }

      .telemetry {
        min-width: 0;
        max-width: 100%;
        width: 100%;
      }

      .nav-links {
        gap: 1.25rem;
      }
    }

    @media (max-width: 480px) {
      .hero {
        padding: 2rem 1rem 0;
      }

      nav {
        padding: 0.875rem 1rem;
      }

      .manifesto {
        padding: 2rem 1rem;
      }

      .cta-link {
        padding: 1.5rem 1rem;
      }

      footer {
        padding: 0.875rem 1rem;
      }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <Nav currentPath={currentPath} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-top">

      <div class="hero-headline-wrap">
        <span class="label hero-eyebrow">SYSTEM ACTIVE // EST. DUBLIN, IE</span>
        <h1 class="hero-headline" aria-label="KINETIC PRINT LAB">
          <span class="stamp-line">KINETIC</span>
          <span class="stamp-line">PRINT</span>
          <span class="stamp-line">LAB</span>
        </h1>
      </div>

      <aside class="telemetry" aria-label="Machine telemetry">
        <div class="telemetry-header">MACHINE TELEMETRY</div>
        <div class="telemetry-row">
          <span class="telemetry-key">CORE</span>
          <span class="telemetry-val">RISOGRAPH RP3700</span>
        </div>
        <div class="telemetry-row">
          <span class="telemetry-key">DRUMS</span>
          <span class="telemetry-val">FLUORO PINK / TOXIC GREEN / CARBON BLACK</span>
        </div>
        <div class="telemetry-row">
          <span class="telemetry-key">STATUS</span>
          <span class="telemetry-val active">
            <span class="status-dot" aria-hidden="true"></span>PRESS RUNNING
          </span>
        </div>
      </aside>

    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto">
    <p class="manifesto-text">
      WE OPERATE IN THE PHYSICAL REALM. WE PRESERVE INK ON PAPER. NO ALGORITHMS.
      NO DIGITAL SUBSCRIPTIONS. WE PRESS INDEPENDENT OBJECTS FOR RADICAL ARCHIVES.
    </p>
  </section>

  <!-- CTA -->
  <div class="cta-section">
    <a href="/zines" class="cta-link">
      <span>ENTER THE ARCHIVE</span>
      <span class="cta-arrow" aria-hidden="true">→</span>
    </a>
  </div>

  <!-- FOOTER -->
  <Footer />

</body>
</html>
