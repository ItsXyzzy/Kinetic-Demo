---
// KINETIC PRINT LAB — FOOTER COMPONENT
// src/components/Footer.astro
---

<footer>
  <div class="footer-left">
    <span class="footer-wordmark">KINETIC PRINT LAB</span>
    <span class="footer-copy">© ALL RUNS LIMITED — DUBLIN, IE</span>
  </div>

  <div class="footer-center">
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/zines">Catalog</a>
      <a href="/stockists">Stockists</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>

  <div class="footer-right">
    <span class="drums-label">ACTIVE DRUMS</span>
    <div class="footer-drums" aria-label="Active Riso drums">
      <span class="drum drum--pink"  title="Fluoro Pink"></span>
      <span class="drum drum--green" title="Toxic Green"></span>
      <span class="drum drum--black" title="Carbon Black"></span>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: var(--border);
    padding: 1.25rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    background: var(--ink-black);
  }

  /* ── LEFT ─────────────────────────────────────────────── */
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: var(--paper);
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    opacity: 0.35;
  }

  /* ── CENTER ───────────────────────────────────────────── */
  .footer-nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .footer-nav a {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    text-decoration: none;
    opacity: 0.4;
    transition: opacity 0.15s;
  }

  .footer-nav a:hover {
    opacity: 1;
  }

  /* ── RIGHT ────────────────────────────────────────────── */
  .footer-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .drums-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.35;
    color: var(--paper);
  }

  .footer-drums {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .drum {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .drum--pink  { background: var(--fluro-pink); }
  .drum--green { background: var(--toxic-green); }
  .drum--black { background: var(--paper); }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 768px) {
    footer {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      padding: 1rem 1.25rem;
    }

    .footer-left {
      grid-column: 1 / 2;
      grid-row: 1;
    }

    .footer-right {
      grid-column: 2 / 3;
      grid-row: 1;
    }

    .footer-center {
      grid-column: 1 / -1;
      grid-row: 2;
      border-top: 1px solid rgba(240, 236, 227, 0.1);
      padding-top: 0.75rem;
      margin-top: 0.25rem;
    }

    .footer-nav {
      gap: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    footer {
      padding: 1rem;
    }

    .footer-nav {
      gap: 1rem;
    }

    .drums-label {
      display: none;
    }
  }
</style>
