---
// KINETIC PRINT LAB — NAV COMPONENT
// src/components/Nav.astro
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
  { href: "/Kinetic-Demo/zines",      label: "Catalog"   },
  { href: "/Kinetic-Demo/archive",    label: "Archive"   },
  { href: "/Kinetic-Demo/stockists",  label: "Stockists" },
  { href: "/Kinetic-Demo/contact",    label: "Contact"   },
];

const { currentPath = "" } = Astro.props;
---

<header class="site-header">
  <nav>
    <a href="/" class="nav-wordmark" aria-label="Home">KINETIC</a>

    <!-- Desktop Menu -->
    <ul class="nav-links">
      {navLinks.map(link => (
        <li class="nav-item">
          <a
            href={link.href}
            class:list={["nav-link", { active: currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right Actions -->
    <div class="nav-actions">
      <ThemeToggle />
      <button class="nav-toggle" aria-label="Open system menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<!-- FULL-SCREEN MOBILE TAKEOVER -->
<div class="mobile-takeover" id="sys-nav" aria-hidden="true">
  <div class="takeover-header">
    <span class="takeover-sys">[ SYS_NAV_ACTIVE ]</span>
    <button class="takeover-close" aria-label="Close system menu">[ X ] CLOSE</button>
  </div>

  <ul class="takeover-links">
    {navLinks.map((link, index) => (
      <li>
        <a
          href={link.href}
          class:list={["takeover-link", { active: currentPath.startsWith(link.href) }]}
          data-index={`0${index + 1}`}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <div class="takeover-footer">
    <span>LAT/LNG: 53.3498° N, 6.2603° W</span>
    <span>OP_MODE: MANUAL</span>
  </div>
</div>

<style>
  /* ── WRAPPER ──────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 900;
    background: var(--ink-black);
    border-bottom: var(--border-thin, 1px solid #333);
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 1.5rem;
    min-height: 60px;
    position: relative;
  }

  /* ── WORDMARK (KINETIC ANIMATION) ─────────────────────── */
  .nav-wordmark {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    color: var(--paper);
    text-decoration: none;
    flex-shrink: 0;
    text-transform: uppercase;
    font-weight: 900;
    transition: none;
  }

  .nav-wordmark:hover {
    color: var(--fluro-pink);
    text-shadow: -3px 3px 0px var(--paper);
    transform: translate(2px, -2px);
  }

  /* ── NAV LINKS (DESKTOP) ──────────────────────────────── */
  .nav-links {
    display: flex;
    height: 60px;
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: var(--border-thin, 1px solid #333);
  }

  .nav-item {
    border-right: var(--border-thin, 1px solid #333);
    display: flex;
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    text-decoration: none;
    transition: none;
  }

  .nav-link:hover,
  .nav-link.active {
    background: var(--paper);
    color: var(--ink-black);
  }

  /* ── RIGHT SIDE ACTIONS ───────────────────────────────── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  /* ── HAMBURGER (DESKTOP HIDDEN) ───────────────────────── */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--paper);
    cursor: pointer;
    padding: 8px;
  }

  .nav-toggle:hover { background: var(--paper); }
  .nav-toggle:hover span { background: var(--ink-black); }

  .nav-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--paper);
  }

  /* ── FULL SCREEN MOBILE TAKEOVER ──────────────────────── */
  .mobile-takeover {
    position: fixed;
    inset: 0; /* Anchors to all 4 corners of the viewport */
    background: var(--ink-black);
    z-index: 9999; /* Absolute top layer */
    display: flex;
    flex-direction: column;
    
    /* The Mechanical Shutter Effect */
    clip-path: inset(0 0 100% 0);
    transition: clip-path 0.4s cubic-bezier(0.77, 0, 0.175, 1);
  }

  .mobile-takeover.open {
    clip-path: inset(0 0 0 0);
  }

  /* Takeover Header */
  .takeover-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: var(--border-thin, 1px solid #333);
  }

  .takeover-sys {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fluro-pink);
    letter-spacing: 0.1em;
  }

  .takeover-close {
    background: transparent;
    border: none;
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
    text-transform: uppercase;
  }
  .takeover-close:hover { color: var(--fluro-pink); }

  /* Takeover Links */
  .takeover-links {
    list-style: none;
    margin: 0;
    padding: 0;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .takeover-link {
    display: flex;
    align-items: flex-start;
    padding: 2rem 1.5rem;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4rem); /* Massive scaling text */
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--paper);
    text-decoration: none;
    border-bottom: var(--border-thin, 1px solid #333);
  }

  /* Diagnostic numbering before the link */
  .takeover-link::before {
    content: attr(data-index);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fluro-pink);
    margin-right: 1.5rem;
    margin-top: 0.25rem;
  }

  .takeover-link:hover,
  .takeover-link.active {
    background: var(--paper);
    color: var(--ink-black);
    padding-left: 2.5rem; /* Harsh physical indentation on active */
  }

  /* Takeover Footer */
  .takeover-footer {
    display: flex;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.4);
    border-top: var(--border-thin, 1px solid #333);
  }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-toggle { display: flex; }
  }
</style>

<script>
  // Runs entirely on the client
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const closeBtn = document.querySelector('.takeover-close') as HTMLButtonElement;
  const takeover = document.querySelector('.mobile-takeover') as HTMLElement;

  function openMenu() {
    takeover.setAttribute('aria-hidden', 'false');
    takeover.classList.add('open');
    // Lock the body from scrolling behind the menu
    document.body.style.overflow = 'hidden'; 
  }

  function closeMenu() {
    takeover.setAttribute('aria-hidden', 'true');
    takeover.classList.remove('open');
    // Release the body scroll lock
    document.body.style.overflow = ''; 
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close instantly if they click a link (essential for smooth routing)
  takeover?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
